# Copy this file to `.env` and fill in real values.
# Local Inngest dev server: `npm run inngest:dev`

# Clerk (https://dashboard.clerk.com) — required for auth; see docs/clerk-auth.md
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
# Optional but recommended for hosted /sign-in and /sign-up routes:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
# Used when users open /sign-in or /sign-up directly and for sign-in/up UI fallbacks (see Clerk custom pages docs).
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"
# Direct Postgres URL (non-pooler). Required for `/api/projects/[id]/stream` LISTEN/NOTIFY when DATABASE_URL uses transaction pooling (e.g. PgBouncer). Falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=your-r2-bucket
# Optional: only used if you want a public base URL recorded in asset metadata.
R2_PUBLIC_BASE_URL=https://your-public-r2-base-url

# Local Inngest development settings.
INNGEST_DEV=1
INNGEST_BASE_URL=http://127.0.0.1:8288
